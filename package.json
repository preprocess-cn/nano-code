{
  "name": "@preprocess-cn/nano-code",
  "version": "0.1.0",
  "description": "A lightweight, CLI-based AI coding assistant with file operations.",
  "imports": {
    "#src/*": "./src/*"
  },
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "nano-code": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/preprocess-cn/nano-code.git"
  },
  "bugs": {
    "url": ""
  },
  "homepage": "",
  "author": "Feng Gao",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && tsc-alias && node -e \"fs.writeFileSync('dist/index.js','#!/usr/bin/env node\\n'+fs.readFileSync('dist/index.js','utf8'))\"",
    "start": "node dist/index.js",
    "dev": "tsc --watch & node --watch dist/index.js",
    "debug": "node dist/index.js --debug",
    "test": "tsc --noEmit -p tsconfig.test.json && node --import tsx --test tests/*.test.ts",
    "test:e2e": "node --import tsx --test tests/e2e/e2e.test.ts",
    "test:all": "node --import tsx --test tests/*.test.ts tests/e2e/e2e.test.ts",
    "install:minimal": "npm install --omit=dev --no-optional",
    "install:default": "npm install --omit=dev",
    "install:full": "npm install"
  },
  "keywords": [
    "cli",
    "ai",
    "agent",
    "claude-code",
    "nano-code",
    "typescript"
  ],
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "cac": "^7.0.0",
    "chalk": "^5.6.2",
    "diff": "^9.0.0",
    "dotenv": "^16.4.7",
    "js-yaml": "^4.2.0",
    "lodash-es": "^4.18.1",
    "marked": "^18.0.5",
    "openai": "^4.86.0",
    "semver": "^7.8.5",
    "signal-exit": "^4.1.0",
    "strip-ansi": "^7.2.0",
    "supports-hyperlinks": "^4.5.0",
    "wrap-ansi": "^10.0.0"
  },
  "optionalDependencies": {
    "@alcalzone/ansi-tokenize": "^0.3.0",
    "auto-bind": "^5.0.1",
    "bidi-js": "^1.0.3",
    "cli-boxes": "^4.0.1",
    "code-excerpt": "^4.0.0",
    "emoji-regex": "^10.6.0",
    "figures": "^6.1.0",
    "get-east-asian-width": "^1.6.0",
    "highlight.js": "^11.11.1",
    "indent-string": "^5.0.0",
    "neo-blessed": "^0.2.0",
    "react": "^19.2.7",
    "react-reconciler": "^0.33.0",
    "stack-utils": "^2.0.6",
    "tiktoken": "^1.0.22",
    "turndown": "^7.2.4",
    "type-fest": "^5.7.0",
    "usehooks-ts": "^3.1.1"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^20.11.0",
    "@types/react": "^19.2.17",
    "@types/semver": "^7.7.1",
    "@types/turndown": "^5.0.6",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.22.4",
    "typescript": "^5.3.3"
  }
}
