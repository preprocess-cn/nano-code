{
  "name": "nano-code",
  "version": "0.1.0",
  "description": "A lightweight, CLI-based AI coding assistant with file operations.",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "nano-code": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc && node -e \"fs.writeFileSync('dist/index.js','#!/usr/bin/env node\\n'+fs.readFileSync('dist/index.js','utf8'))\"",
    "start": "node dist/index.js",
    "dev": "tsc --watch & node --watch dist/index.js",
    "debug": "node dist/index.js --debug",
    "test": "node --import tsx --test tests/*.test.ts"
  },
  "keywords": [
    "cli",
    "ai",
    "agent",
    "claude-code",
    "nano-code",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "cac": "^7.0.0",
    "dotenv": "^16.4.7",
    "openai": "^4.86.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.22.4",
    "typescript": "^5.3.3"
  }
}
